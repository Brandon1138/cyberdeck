{
  "name": "@brandon1138/cyberdeck",
  "version": "0.1.0-alpha.1",
  "description": "A provider-neutral local control plane for durable AI coding-agent sessions.",
  "license": "Apache-2.0",
  "author": "Brandon Aron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brandon1138/cyberdeck.git"
  },
  "homepage": "https://github.com/Brandon1138/cyberdeck#readme",
  "bugs": {
    "url": "https://github.com/Brandon1138/cyberdeck/issues"
  },
  "keywords": [
    "ai-agents",
    "cli",
    "codex",
    "claude",
    "terminal",
    "tmux"
  ],
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "os": [
    "darwin"
  ],
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "TRADEMARKS.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "cyberdeck": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm test && pnpm check",
    "pretest": "pnpm run postinstall",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe": "tsx scripts/probe-runtimes.ts",
    "gate:live-codex": "tsx scripts/run-live-codex-gate.ts",
    "dev": "tsx src/cli.ts",
    "postinstall": "node -e \"const fs=require('node:fs'),path=require('node:path');if(process.platform==='darwin'){const helper=path.join(path.dirname(require.resolve('node-pty/package.json')),'prebuilds',process.platform+'-'+process.arch,'spawn-helper');if(fs.existsSync(helper))fs.chmodSync(helper,0o755)}\""
  },
  "dependencies": {
    "commander": "^15.0.0",
    "node-pty": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
